{
    "info": {
        "name": "Mini Project Management API",
        "description": "API collection for MiniMT project management application.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Login",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/auth/login/",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "login",
                        "access-token"
                    ]
                }
            }
        },
        {
            "name": "Create User",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"developer\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/users/",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "users",
                        ""
                    ]
                }
            }
        },
        {
            "name": "Get Users",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:8000/users/",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "users",
                        ""
                    ]
                }
            }
        },
        {
            "name": "Create Project",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"New Website Redesign\",\n  \"description\": \"Redesign the corporate website with Next.js\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/projects/",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "projects",
                        ""
                    ]
                }
            }
        },
        {
            "name": "Get Projects",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:8000/projects/",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "projects",
                        ""
                    ]
                }
            }
        },
        {
            "name": "Create Task",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Setup Database schema\",\n  \"description\": \"Design and implement Postgres DB\",\n  \"status\": \"pending\",\n  \"project_id\": 1,\n  \"assigned_to\": 1\n  \"due_date\": "2026-04-01T10:00:00"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/tasks/",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "tasks",
                        ""
                    ]
                }
            }
        },
        {
            "name": "Get Tasks by Project",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:8000/tasks/?project_id=1",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "tasks",
                        ""
                    ],
                    "query": [
                        {
                            "key": "project_id",
                            "value": "1"
                        }
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "token",
            "value": "YOUR_JWT_TOKEN_HERE"
        }
    ],

    {
        "name": "Assign Task",
        "request": {
            "method": "PUT",
            "header": [
                { "key": "Authorization", "value": "Bearer {{token}}" },
                { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
                "mode": "raw",
                "raw": "{\n  \"assigned_to\": 1\n}"
            },
            "url": {
                "raw": "http://localhost:8000/api/tasks/1/assign",
                "protocol": "http",
                "host": ["localhost"],
                "port": "8000",
                "path": ["api", "tasks", "1", "assign"]
            }
        }
    },

    {
        "name": "Update Task Status",
        "request": {
            "method": "PUT",
            "header": [
                { "key": "Authorization", "value": "Bearer {{token}}" },
                { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
                "mode": "raw",
                "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": {
                "raw": "http://localhost:8000/api/tasks/1/status",
                "protocol": "http",
                "host": ["localhost"],
                "port": "8000",
                "path": ["api", "tasks", "1", "status"]
            }
        }
    },

    {
        "name": "Get Tasks Paginated",
        "request": {
            "method": "GET",
            "header": [
                { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
                "raw": "http://localhost:8000/api/tasks/?project_id=1&skip=0&limit=10",
                "protocol": "http",
                "host": ["localhost"],
                "port": "8000",
                "path": ["api", "tasks", ""],
                "query": [
                    { "key": "project_id", "value": "1" },
                    { "key": "skip", "value": "0", "description": "Number of items to skip" },
                    { "key": "limit", "value": "10", "description": "Number of items to return" }
                ]
            }
        }
    }
}